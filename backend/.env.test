SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASS=test_password
SMTP_FROM="Test System" <test@example.com>

# ==================== FRONTEND ====================
FRONTEND_URL=http://localhost:3000
