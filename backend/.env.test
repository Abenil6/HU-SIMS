# ==================== TEST ENVIRONMENT ====================
NODE_ENV=test

# ==================== SERVER CONFIG ====================
PORT=5002
JWT_SECRET=test_jwt_secret_key_for_testing_only
JWT_EXPIRES_IN=1d

# ==================== MONGODB TEST DATABASE ====================
# Use local MongoDB for fast tests (recommended for development)
TEST_MONGO_URI=mongodb://localhost:27017/sims_test

# Alternative: Use MongoDB Atlas (for CI/CD or when local isn't available)
# TEST_MONGO_URI=mongodb+srv://abenilee740_mdb:abenzo62@clustergm.bpft292.mongodb.net/sims_test_db?appName=ClusterGM

# ==================== EMAIL CONFIGURATION (DISABLED FOR TESTS) ====================
